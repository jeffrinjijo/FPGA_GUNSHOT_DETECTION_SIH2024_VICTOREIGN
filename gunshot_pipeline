    "    def unfreeze_backbone(self):\n",
    "        for p in self.backbone.parameters():\n",
    "            p.requires_grad = False\n",
    "        for p in self.head.parameters():\n",
    "            p.requires_grad = True\n",
    "\n",
    "def build_models():\n",
    "    registry = {\n",
