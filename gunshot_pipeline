    "def load_fixed_audio(path):\n",
    "    target = int(CFG[\"sample_rate\"] * CFG[\"segment_duration\"])\n",
    "    y, _ = librosa.load(path, sr=CFG[\"sample_rate\"], mono=True)\n",
    "    if len(y) > target:\n",
